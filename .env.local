# ============================================================
# MC FABS MASTERCLASS — Server Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit the real .env file.
# ============================================================

# Zainpay (Redirect/Card payment channel) — secret keys, server-side only
ZAINPAY_TEST_SECRET_KEY=your_sandbox_secret_key_here
ZAINPAY_TEST_ZAINBOX_CODE=your_sandbox_zainbox_code_here

ZAINPAY_LIVE_SECRET_KEY=your_live_secret_key_here
ZAINPAY_LIVE_ZAINBOX_CODE=your_live_zainbox_code_here

# Public base URL of your deployed app, used to build Zainpay's callBackUrl
# e.g. https://your-app.onrender.com  (no trailing slash)
PUBLIC_URL=http://localhost:3000

# Port for the Express server (server.js)
PORT=3000
