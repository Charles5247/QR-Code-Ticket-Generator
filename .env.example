# ============================================================
# MC FABS MASTERCLASS — Server Environment Variables
# ============================================================
# Copy this file to .env for local development.
# On Render.com, set these in the Environment Variables panel.
# NEVER commit a file containing real secrets.
# ============================================================

# ── ZainPay (Redirect / Card channel) — SERVER-SIDE ONLY ─────────────────────
# These NEVER go in the frontend. They are only read by server.js on Render.

# Sandbox credentials (used when ZAINPAY_IS_TEST is not "false")
ZAINPAY_TEST_SECRET_KEY=your_sandbox_secret_key_here
ZAINPAY_TEST_ZAINBOX_CODE=your_sandbox_zainbox_code_here

# Production / Live credentials
ZAINPAY_LIVE_SECRET_KEY=your_live_secret_key_here
ZAINPAY_LIVE_ZAINBOX_CODE=your_live_zainbox_code_here

# Set to "false" to switch the server to live mode (overrides the frontend flag)
# Leave unset or set to "true" to stay in sandbox mode
ZAINPAY_IS_TEST=true

# ── Public URL ────────────────────────────────────────────────────────────────
# The public HTTPS URL of your deployed app — used to build the ZainPay callBackUrl.
# Example: https://fabs-masterclass.onrender.com  (NO trailing slash)
PUBLIC_URL=http://localhost:3000

# Optional: URL of the event logo shown on the ZainPay checkout page
# LOGO_URL=https://your-cdn.com/logo.png

# ── Express server port ───────────────────────────────────────────────────────
# Render sets PORT automatically — leave as 3000 for local dev
PORT=3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# These are the browser-safe (publishable) credentials.
# They are baked into the frontend build via config.js.
# You can also set them here for reference, but they are NOT read by server.js.
VITE_SUPABASE_URL=https://vurousvjgwonvabutaom.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_KvOghUmo4Lg7k1-7xP67HA_k_H-ItyS
